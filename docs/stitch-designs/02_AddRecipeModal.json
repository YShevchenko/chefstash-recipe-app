{"screenId":"8c15d855aa524802a778f5d0685c1e36","projectId":"16569787223374756032","htmlContent":"<!DOCTYPE html>\n\n<html lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&amp;family=Work+Sans:ital,wght@0,100..900;1,100..900&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"surface-container-high\": \"#e8e8e8\",\n              \"on-secondary-fixed\": \"#1b1b1b\",\n              \"on-secondary\": \"#ffffff\",\n              \"on-secondary-fixed-variant\": \"#474747\",\n              \"on-tertiary-fixed-variant\": \"#474747\",\n              \"secondary-fixed-dim\": \"#c6c6c6\",\n              \"on-background\": \"#1b1b1b\",\n              \"tertiary-fixed\": \"#e2e2e2\",\n              \"inverse-on-surface\": \"#f1f1f1\",\n              \"surface-container\": \"#eeeeee\",\n              \"on-tertiary\": \"#ffffff\",\n              \"secondary-fixed\": \"#e2e2e2\",\n              \"on-primary-fixed-variant\": \"#812900\",\n              \"on-error\": \"#ffffff\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"primary\": \"#a93800\",\n              \"on-primary-container\": \"#551800\",\n              \"primary-container\": \"#ff5f15\",\n              \"surface-variant\": \"#e2e2e2\",\n              \"surface-container-low\": \"#f3f3f3\",\n              \"on-surface\": \"#1b1b1b\",\n              \"surface-container-highest\": \"#e2e2e2\",\n              \"on-error-container\": \"#93000a\",\n              \"inverse-surface\": \"#303030\",\n              \"background\": \"#f9f9f9\",\n              \"tertiary\": \"#5e5e5e\",\n              \"error\": \"#ba1a1a\",\n              \"on-primary-fixed\": \"#380d00\",\n              \"tertiary-fixed-dim\": \"#c6c6c6\",\n              \"surface-tint\": \"#a93800\",\n              \"on-primary\": \"#ffffff\",\n              \"secondary\": \"#5e5e5e\",\n              \"primary-fixed-dim\": \"#ffb59b\",\n              \"surface\": \"#f9f9f9\",\n              \"on-tertiary-fixed\": \"#1b1b1b\",\n              \"secondary-container\": \"#e2e2e2\",\n              \"primary-fixed\": \"#ffdbcf\",\n              \"on-surface-variant\": \"#5b4138\",\n              \"surface-dim\": \"#dadada\",\n              \"outline-variant\": \"#e3bfb2\",\n              \"on-tertiary-container\": \"#2d2d2d\",\n              \"inverse-primary\": \"#ffb59b\",\n              \"error-container\": \"#ffdad6\",\n              \"outline\": \"#8f7066\",\n              \"on-secondary-container\": \"#646464\",\n              \"tertiary-container\": \"#949494\",\n              \"surface-bright\": \"#f9f9f9\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Work Sans\"],\n              \"label\": [\"Space Grotesk\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0px\", \"lg\": \"0px\", \"xl\": \"0px\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .hard-shadow-btn:active {\n            transform: translate(4px, 4px);\n            box-shadow: 0px 0px 0px transparent;\n        }\n        .hard-shadow-btn {\n            box-shadow: 4px 4px 0px #ff5f15;\n            transition: all 0.1s ease-in-out;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-[#1b1b1b] min-h-screen flex items-center justify-center p-0 md:p-8 font-body\">\n<!-- Modal Container -->\n<div class=\"relative w-full max-w-lg bg-surface min-h-[795px] md:min-h-0 flex flex-col border-4 border-on-surface\">\n<!-- Header: Contextual suppression of Shell Nav as per task (Modal Context) -->\n<header class=\"flex justify-between items-center w-full px-6 py-8 border-b-4 border-on-surface\">\n<h1 class=\"text-4xl font-black font-headline tracking-tighter uppercase text-on-surface\">NEW ENTRY</h1>\n<button class=\"w-12 h-12 flex items-center justify-center border-2 border-on-surface hover:bg-primary-container active:translate-x-1 active:translate-y-1\">\n<span class=\"material-symbols-outlined text-on-surface\" data-icon=\"close\">close</span>\n</button>\n</header>\n<!-- Main Modal Content -->\n<main class=\"flex-grow flex flex-col justify-center px-6 py-12 gap-12\">\n<!-- Graphic Element / Abstract Blueprint Accent -->\n<div class=\"w-full h-32 border-2 border-on-surface relative overflow-hidden bg-surface-container-low\">\n<div class=\"absolute inset-0 opacity-10\" style=\"background-image: linear-gradient(90deg, #1b1b1b 1px, transparent 1px), linear-gradient(#1b1b1b 1px, transparent 1px); background-size: 20px 20px;\"></div>\n<div class=\"absolute bottom-4 left-4\">\n<p class=\"font-label text-[10px] font-bold tracking-[0.2em] text-tertiary\">STARK_SYSTEM // MODULE_01</p>\n</div>\n<div class=\"absolute top-0 right-0 p-2\">\n<span class=\"material-symbols-outlined text-primary-container text-4xl\" data-icon=\"restaurant_menu\" data-weight=\"fill\" style=\"font-variation-settings: 'FILL' 1;\">restaurant_menu</span>\n</div>\n</div>\n<!-- Input Section -->\n<div class=\"space-y-4\">\n<label class=\"block font-label text-xs font-black tracking-widest text-on-surface uppercase\">SOURCE_URL</label>\n<div class=\"relative group\">\n<input class=\"w-full bg-surface border-4 border-on-surface px-6 py-8 font-headline font-bold text-xl placeholder:text-surface-container-highest focus:ring-0 focus:border-primary-container outline-none transition-colors\" placeholder=\"PASTE RECIPE URL HERE\" type=\"text\"/>\n<div class=\"absolute right-6 top-1/2 -translate-y-1/2\">\n<span class=\"material-symbols-outlined text-on-surface opacity-30\" data-icon=\"link\">link</span>\n</div>\n</div>\n</div>\n<!-- Action Section -->\n<div class=\"space-y-8\">\n<button class=\"w-full bg-on-surface text-surface font-headline font-black text-2xl py-8 uppercase tracking-tight hard-shadow-btn flex items-center justify-center gap-4\">\n<span>EXTRACT RECIPE</span>\n<span class=\"material-symbols-outlined\" data-icon=\"bolt\" data-weight=\"fill\" style=\"font-variation-settings: 'FILL' 1;\">bolt</span>\n</button>\n<div class=\"flex flex-col items-center gap-4\">\n<a class=\"font-headline font-bold text-on-surface hover:text-primary-container underline decoration-4 underline-offset-8 decoration-on-surface hover:decoration-primary-container transition-all uppercase tracking-widest text-sm\" href=\"#\">\n                        Or add manually\n                    </a>\n</div>\n</div>\n<!-- Visual Metadata / Aesthetic Filler -->\n<div class=\"mt-auto pt-12 grid grid-cols-2 gap-4 border-t-2 border-on-surface/10 pt-8\">\n<div>\n<span class=\"block font-label text-[10px] text-tertiary uppercase tracking-widest\">Supported Engines</span>\n<span class=\"block font-headline font-bold text-on-surface text-xs mt-1\">NYT COOKING, EPICURIOUS, BON APPETIT</span>\n</div>\n<div class=\"text-right\">\n<span class=\"block font-label text-[10px] text-tertiary uppercase tracking-widest\">Status</span>\n<span class=\"block font-headline font-bold text-primary-container text-xs mt-1 italic\">SYSTEM_READY_</span>\n</div>\n</div>\n</main>\n<!-- Aesthetic Footer Block -->\n<footer class=\"h-4 bg-on-surface w-full\"></footer>\n</div>\n<!-- Hidden decorative background element for desktop view -->\n<div class=\"hidden md:block fixed top-10 right-10 -z-10 opacity-20 pointer-events-none\">\n<h2 class=\"font-headline font-black text-[12vw] leading-none text-surface-container-highest select-none\">KITCHEN</h2>\n</div>\n</body></html>"}
