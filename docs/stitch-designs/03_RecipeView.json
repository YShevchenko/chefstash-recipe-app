{"screenId":"aa3b001d6e1f4994a24ef0275fa5e0fe","projectId":"16569787223374756032","htmlContent":"<!DOCTYPE html>\n\n<html lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&amp;family=Work+Sans:wght@300..700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"surface-variant\": \"#e2e2e2\",\n              \"error\": \"#ba1a1a\",\n              \"on-error-container\": \"#93000a\",\n              \"on-tertiary-fixed\": \"#1b1b1b\",\n              \"error-container\": \"#ffdad6\",\n              \"on-surface\": \"#1b1b1b\",\n              \"surface-bright\": \"#f9f9f9\",\n              \"inverse-on-surface\": \"#f1f1f1\",\n              \"on-primary-container\": \"#551800\",\n              \"tertiary\": \"#5e5e5e\",\n              \"outline-variant\": \"#e3bfb2\",\n              \"secondary-fixed-dim\": \"#c6c6c6\",\n              \"on-background\": \"#1b1b1b\",\n              \"tertiary-fixed-dim\": \"#c6c6c6\",\n              \"on-tertiary-fixed-variant\": \"#474747\",\n              \"secondary\": \"#5e5e5e\",\n              \"on-secondary-fixed\": \"#1b1b1b\",\n              \"on-secondary-fixed-variant\": \"#474747\",\n              \"tertiary-fixed\": \"#e2e2e2\",\n              \"secondary-fixed\": \"#e2e2e2\",\n              \"tertiary-container\": \"#949494\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"on-tertiary-container\": \"#2d2d2d\",\n              \"on-primary-fixed-variant\": \"#812900\",\n              \"surface-container-high\": \"#e8e8e8\",\n              \"secondary-container\": \"#e2e2e2\",\n              \"on-secondary\": \"#ffffff\",\n              \"surface-container-highest\": \"#e2e2e2\",\n              \"on-surface-variant\": \"#5b4138\",\n              \"surface-dim\": \"#dadada\",\n              \"inverse-surface\": \"#303030\",\n              \"outline\": \"#8f7066\",\n              \"on-secondary-container\": \"#646464\",\n              \"on-error\": \"#ffffff\",\n              \"inverse-primary\": \"#ffb59b\",\n              \"surface\": \"#f9f9f9\",\n              \"primary-fixed\": \"#ffdbcf\",\n              \"surface-container-low\": \"#f3f3f3\",\n              \"primary-fixed-dim\": \"#ffb59b\",\n              \"on-primary-fixed\": \"#380d00\",\n              \"on-primary\": \"#ffffff\",\n              \"surface-tint\": \"#a93800\",\n              \"surface-container\": \"#eeeeee\",\n              \"on-tertiary\": \"#ffffff\",\n              \"primary\": \"#a93800\",\n              \"background\": \"#f9f9f9\",\n              \"primary-container\": \"#ff5f15\"\n            },\n            fontFamily: {\n              \"headline\": [\"Space Grotesk\"],\n              \"body\": [\"Work Sans\"],\n              \"label\": [\"Space Grotesk\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0px\", \"lg\": \"0px\", \"xl\": \"0px\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        /* Custom scrollbar for brutalist feel */\n        ::-webkit-scrollbar { width: 8px; }\n        ::-webkit-scrollbar-track { background: #f9f9f9; }\n        ::-webkit-scrollbar-thumb { background: #1b1b1b; border: 2px solid #f9f9f9; }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface text-on-surface font-body antialiased\">\n<!-- Top Navigation Anchor -->\n<header class=\"flex justify-between items-center w-full px-4 h-16 bg-white dark:bg-stone-950 docked full-width top-0 border-b-4 border-black dark:border-white fixed z-50\">\n<div class=\"flex items-center gap-2 active:translate-x-0.5 active:translate-y-0.5 transition-transform\">\n<span class=\"material-symbols-outlined text-black dark:text-white\">arrow_back</span>\n</div>\n<h1 class=\"font-['Space_Grotesk'] font-bold uppercase tracking-tight text-[#a93800] dark:text-[#ff5f15] text-xl\">RECIPE</h1>\n<div class=\"flex items-center gap-2 active:translate-x-0.5 active:translate-y-0.5 transition-transform\">\n<span class=\"material-symbols-outlined text-black dark:text-white\">more_vert</span>\n</div>\n</header>\n<main class=\"pt-16 pb-40\">\n<!-- Hero Section -->\n<section class=\"relative w-full border-b-4 border-on-surface\">\n<img class=\"w-full h-80 object-cover grayscale-[0.2]\" data-alt=\"Close-up of authentic Spaghetti Carbonara with glossy egg sauce, crispy guanciale, and cracked black pepper in a minimalist white bowl\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBYFtsKi-xg96Oz4sHvMb6E-r0LEbTQVU1OBAaSH-B9dMYARh22nobMWerE7CMyzqUIl7GdkW7nDNpnosjcO9tbzAjbLJ90Ts7Wt6vCyoaTeVKr_GDznqwsljUPAUIDIyRVzFX-wmHGSCngSEbH3YTm9deffgnV_b703Dli7UFX-so_z9lPRnPQ4rxjrUMzzUjDebGktwGO4cGGwXaYiEBYvmK37RYtreWT99lUpiaxrK2R8fHfqF_X_25WnEKaNwn_0PiSLFhW189k\"/>\n<div class=\"absolute bottom-0 left-0 w-full p-6 bg-gradient-to-t from-on-surface/80 to-transparent\">\n<h2 class=\"font-headline font-black text-4xl text-white leading-none tracking-tighter uppercase\">\n                    SPAGHETTI<br/>CARBONARA\n                </h2>\n</div>\n</section>\n<!-- Stats Bar -->\n<div class=\"grid grid-cols-3 border-b-4 border-on-surface bg-white\">\n<div class=\"p-4 border-r-2 border-on-surface flex flex-col items-center\">\n<span class=\"font-label font-bold text-[10px] tracking-widest text-tertiary\">TIME</span>\n<span class=\"font-headline font-bold text-lg\">20 MIN</span>\n</div>\n<div class=\"p-4 border-r-2 border-on-surface flex flex-col items-center\">\n<span class=\"font-label font-bold text-[10px] tracking-widest text-tertiary\">LEVEL</span>\n<span class=\"font-headline font-bold text-lg\">PRO</span>\n</div>\n<div class=\"p-4 flex flex-col items-center\">\n<span class=\"font-label font-bold text-[10px] tracking-widest text-tertiary\">SERVES</span>\n<span class=\"font-headline font-bold text-lg\">02</span>\n</div>\n</div>\n<!-- Sticky Tabs -->\n<nav class=\"sticky top-16 bg-surface z-40 flex border-b-4 border-on-surface\">\n<button class=\"flex-1 py-4 font-headline font-bold text-sm tracking-widest bg-stone-100 border-r-2 border-on-surface text-primary\">\n                INGREDIENTS\n            </button>\n<button class=\"flex-1 py-4 font-headline font-bold text-sm tracking-widest text-on-surface hover:bg-stone-100\">\n                INSTRUCTIONS\n            </button>\n</nav>\n<!-- Ingredients List -->\n<section class=\"p-6 space-y-4\">\n<div class=\"flex items-end justify-between border-b-2 border-outline-variant pb-2\">\n<span class=\"font-body text-lg font-medium\">Spaghetti (Bronze Die)</span>\n<span class=\"font-mono text-primary font-bold text-xl\">200G</span>\n</div>\n<div class=\"flex items-end justify-between border-b-2 border-outline-variant pb-2\">\n<span class=\"font-body text-lg font-medium\">Guanciale / Pancetta</span>\n<span class=\"font-mono text-primary font-bold text-xl\">150G</span>\n</div>\n<div class=\"flex items-end justify-between border-b-2 border-outline-variant pb-2\">\n<span class=\"font-body text-lg font-medium\">Pecorino Romano</span>\n<span class=\"font-mono text-primary font-bold text-xl\">60G</span>\n</div>\n<div class=\"flex items-end justify-between border-b-2 border-outline-variant pb-2\">\n<span class=\"font-body text-lg font-medium\">Fresh Egg Yolks</span>\n<span class=\"font-mono text-primary font-bold text-xl\">04</span>\n</div>\n<div class=\"flex items-end justify-between border-b-2 border-outline-variant pb-2\">\n<span class=\"font-body text-lg font-medium\">Black Peppercorns</span>\n<span class=\"font-mono text-primary font-bold text-xl\">10G</span>\n</div>\n<div class=\"flex items-end justify-between border-b-2 border-outline-variant pb-2\">\n<span class=\"font-body text-lg font-medium\">Sea Salt</span>\n<span class=\"font-mono text-primary font-bold text-xl\">Q.B.</span>\n</div>\n</section>\n<!-- Editorial Note -->\n<section class=\"mx-6 p-6 bg-on-surface text-white border-2 border-on-surface\">\n<h4 class=\"font-headline font-bold text-xs tracking-widest mb-2 text-primary-container\">CHEF'S MANDATE</h4>\n<p class=\"font-body text-sm leading-relaxed italic\">\n                \"Do not use cream. The emulsion of egg yolk, pasta water, and rendered fat is the only legitimate sauce.\"\n            </p>\n</section>\n</main>\n<!-- Fixed Action and Bottom Nav Container -->\n<div class=\"fixed bottom-0 left-0 w-full z-50\">\n<!-- Floating Action Button Styled as Monolith -->\n<div class=\"px-4 pb-4\">\n<button class=\"w-full bg-primary-container text-on-primary-container font-headline font-black text-xl py-6 border-4 border-on-surface active:translate-x-1 active:translate-y-1 transition-all shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex items-center justify-center gap-3\">\n<span class=\"material-symbols-outlined font-bold\">restaurant</span>\n                ENTER COOKING MODE\n            </button>\n</div>\n<!-- Bottom Navigation Shell -->\n<nav class=\"w-full z-50 flex justify-around items-center h-20 bg-white dark:bg-stone-950 border-t-4 border-black dark:border-white\">\n<a class=\"flex flex-col items-center justify-center text-black dark:text-white px-4 py-2 hover:bg-stone-200 dark:hover:bg-stone-800 active:scale-95 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">grid_view</span>\n<span class=\"font-['Space_Grotesk'] font-bold text-[10px] uppercase tracking-widest\">EXPLORE</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#a93800] dark:text-[#ff5f15] border-x-2 border-black dark:border-white bg-stone-100 dark:bg-stone-900 px-4 py-2 active:scale-95 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">bookmark</span>\n<span class=\"font-['Space_Grotesk'] font-bold text-[10px] uppercase tracking-widest\">SAVED</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-black dark:text-white px-4 py-2 hover:bg-stone-200 dark:hover:bg-stone-800 active:scale-95 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">restaurant</span>\n<span class=\"font-['Space_Grotesk'] font-bold text-[10px] uppercase tracking-widest\">PANTRY</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-black dark:text-white px-4 py-2 hover:bg-stone-200 dark:hover:bg-stone-800 active:scale-95 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined\">person</span>\n<span class=\"font-['Space_Grotesk'] font-bold text-[10px] uppercase tracking-widest\">PROFILE</span>\n</a>\n</nav>\n</div>\n</body></html>"}
