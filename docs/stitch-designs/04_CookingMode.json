{"screenId":"c5eaa9430d0a4f19a75f31a7bbe74f19","projectId":"16569787223374756032","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Stark Kitchen - COOKING MODE</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&amp;family=Work+Sans:wght@300;400;600;800&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        /* Custom scrollbar for brutalist feel */\n        ::-webkit-scrollbar {\n            width: 12px;\n        }\n        ::-webkit-scrollbar-track {\n            background: #f9f9f9;\n            border-left: 4px solid #1b1b1b;\n        }\n        ::-webkit-scrollbar-thumb {\n            background: #1b1b1b;\n        }\n    </style>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"on-primary-container\": \"#551800\",\n                        \"tertiary-container\": \"#949494\",\n                        \"surface-bright\": \"#f9f9f9\",\n                        \"inverse-primary\": \"#ffb59b\",\n                        \"surface-container-highest\": \"#e2e2e2\",\n                        \"error-container\": \"#ffdad6\",\n                        \"primary-fixed-dim\": \"#ffb59b\",\n                        \"on-surface\": \"#1b1b1b\",\n                        \"primary-fixed\": \"#ffdbcf\",\n                        \"tertiary-fixed\": \"#e2e2e2\",\n                        \"outline\": \"#8f7066\",\n                        \"on-primary\": \"#ffffff\",\n                        \"inverse-on-surface\": \"#f1f1f1\",\n                        \"secondary-fixed\": \"#e2e2e2\",\n                        \"primary-container\": \"#ff5f15\",\n                        \"on-secondary-fixed-variant\": \"#474747\",\n                        \"on-secondary\": \"#ffffff\",\n                        \"on-error\": \"#ffffff\",\n                        \"tertiary\": \"#5e5e5e\",\n                        \"primary\": \"#a93800\",\n                        \"on-tertiary\": \"#ffffff\",\n                        \"on-primary-fixed\": \"#380d00\",\n                        \"on-tertiary-fixed-variant\": \"#474747\",\n                        \"on-secondary-container\": \"#646464\",\n                        \"on-tertiary-fixed\": \"#1b1b1b\",\n                        \"inverse-surface\": \"#303030\",\n                        \"tertiary-fixed-dim\": \"#c6c6c6\",\n                        \"secondary\": \"#5e5e5e\",\n                        \"secondary-container\": \"#e2e2e2\",\n                        \"on-background\": \"#1b1b1b\",\n                        \"on-tertiary-container\": \"#2d2d2d\",\n                        \"surface-variant\": \"#e2e2e2\",\n                        \"secondary-fixed-dim\": \"#c6c6c6\",\n                        \"outline-variant\": \"#e3bfb2\",\n                        \"surface-container-lowest\": \"#ffffff\",\n                        \"surface-container-low\": \"#f3f3f3\",\n                        \"surface-dim\": \"#dadada\",\n                        \"on-surface-variant\": \"#5b4138\",\n                        \"surface-container-high\": \"#e8e8e8\",\n                        \"surface-container\": \"#eeeeee\",\n                        \"surface-tint\": \"#a93800\",\n                        \"on-secondary-fixed\": \"#1b1b1b\",\n                        \"error\": \"#ba1a1a\",\n                        \"background\": \"#f9f9f9\",\n                        \"on-primary-fixed-variant\": \"#812900\",\n                        \"surface\": \"#f9f9f9\",\n                        \"on-error-container\": \"#93000a\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Space Grotesk\"],\n                        \"body\": [\"Work Sans\"],\n                        \"label\": [\"Space Grotesk\"]\n                    },\n                    borderRadius: { \"DEFAULT\": \"0px\", \"lg\": \"0px\", \"xl\": \"0px\", \"full\": \"9999px\" },\n                },\n            },\n        }\n    </script>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-background text-on-surface font-body overflow-hidden\">\n<!-- TopAppBar -->\n<header class=\"flex justify-between items-center px-6 h-20 w-full bg-white dark:bg-stone-900 border-b-4 border-black dark:border-white z-50 fixed top-0 left-0\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-black dark:text-white text-3xl\">close</span>\n<h1 class=\"font-['Space_Grotesk'] font-bold tracking-tighter uppercase text-[#a93800] dark:text-[#ff5f15] text-2xl\">COOKING MODE</h1>\n</div>\n<button class=\"font-['Space_Grotesk'] font-bold tracking-tighter uppercase text-black dark:text-white hover:bg-[#ff5f15] hover:text-white transition-transform active:translate-x-1 active:translate-y-1 px-4 py-2 border-2 border-black\">\n            EXIT\n        </button>\n</header>\n<!-- Main Content: Vertical Split Container -->\n<main class=\"flex flex-col md:flex-row h-screen pt-20 pb-24\">\n<!-- Left Side: Ingredients List (Scrollable) -->\n<section class=\"w-full md:w-1/3 h-1/2 md:h-full overflow-y-auto border-b-4 md:border-b-0 md:border-r-4 border-black bg-surface-container-low\">\n<div class=\"p-6\">\n<h2 class=\"font-headline font-black text-3xl mb-8 uppercase tracking-tighter border-b-4 border-black pb-2 inline-block\">Ingredients</h2>\n<div class=\"space-y-6\">\n<!-- Ingredient Item -->\n<label class=\"flex items-center group cursor-pointer\">\n<div class=\"relative\">\n<input class=\"peer sr-only\" type=\"checkbox\"/>\n<div class=\"w-12 h-12 border-4 border-black bg-white peer-checked:bg-primary transition-colors flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-white opacity-0 peer-checked:opacity-100\" style=\"font-variation-settings: 'FILL' 1;\">check</span>\n</div>\n</div>\n<div class=\"ml-4\">\n<p class=\"font-headline font-bold text-xl uppercase leading-none group-hover:text-primary transition-colors\">Guanciale</p>\n<p class=\"font-body text-sm font-semibold text-secondary\">200G • CUBED</p>\n</div>\n</label>\n<label class=\"flex items-center group cursor-pointer\">\n<div class=\"relative\">\n<input checked=\"\" class=\"peer sr-only\" type=\"checkbox\"/>\n<div class=\"w-12 h-12 border-4 border-black bg-white peer-checked:bg-primary transition-colors flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-white opacity-0 peer-checked:opacity-100\" style=\"font-variation-settings: 'FILL' 1;\">check</span>\n</div>\n</div>\n<div class=\"ml-4\">\n<p class=\"font-headline font-bold text-xl uppercase leading-none line-through opacity-50\">Pecorino Romano</p>\n<p class=\"font-body text-sm font-semibold text-secondary\">100G • FINELY GRATED</p>\n</div>\n</label>\n<label class=\"flex items-center group cursor-pointer\">\n<div class=\"relative\">\n<input class=\"peer sr-only\" type=\"checkbox\"/>\n<div class=\"w-12 h-12 border-4 border-black bg-white peer-checked:bg-primary transition-colors flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-white opacity-0 peer-checked:opacity-100\" style=\"font-variation-settings: 'FILL' 1;\">check</span>\n</div>\n</div>\n<div class=\"ml-4\">\n<p class=\"font-headline font-bold text-xl uppercase leading-none\">Spaghetti</p>\n<p class=\"font-body text-sm font-semibold text-secondary\">400G • ARTISAN BRONZE-CUT</p>\n</div>\n</label>\n<label class=\"flex items-center group cursor-pointer\">\n<div class=\"relative\">\n<input class=\"peer sr-only\" type=\"checkbox\"/>\n<div class=\"w-12 h-12 border-4 border-black bg-white peer-checked:bg-primary transition-colors flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-white opacity-0 peer-checked:opacity-100\" style=\"font-variation-settings: 'FILL' 1;\">check</span>\n</div>\n</div>\n<div class=\"ml-4\">\n<p class=\"font-headline font-bold text-xl uppercase leading-none\">Egg Yolks</p>\n<p class=\"font-body text-sm font-semibold text-secondary\">4 LARGE • ORGANIC</p>\n</div>\n</label>\n<label class=\"flex items-center group cursor-pointer\">\n<div class=\"relative\">\n<input class=\"peer sr-only\" type=\"checkbox\"/>\n<div class=\"w-12 h-12 border-4 border-black bg-white peer-checked:bg-primary transition-colors flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-white opacity-0 peer-checked:opacity-100\" style=\"font-variation-settings: 'FILL' 1;\">check</span>\n</div>\n</div>\n<div class=\"ml-4\">\n<p class=\"font-headline font-bold text-xl uppercase leading-none\">Black Pepper</p>\n<p class=\"font-body text-sm font-semibold text-secondary\">FRESHLY CRACKED • TO TASTE</p>\n</div>\n</label>\n</div>\n<!-- Instructional Image Accent -->\n<div class=\"mt-12 border-4 border-black overflow-hidden bg-black\">\n<img alt=\"Carbonara ingredients\" class=\"w-full h-48 object-cover grayscale contrast-125 opacity-80\" data-alt=\"Close-up of cubed guanciale and a wedge of pecorino romano on a dark wooden board, harsh lighting, brutalist food photography style\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAWUVIicyh2AfhD12nK3OYRkunq5iG_3eezmG7tx_xFlPjiw_Yu3cDY5COJ4tsknXs_Ntu4Q7hKqimZUOObhy0i3Rx1PoPrwwGkCc91hyZaAyG9PKqBEnNJl0iy4u5KHsKImZ-Espm9y6NVip0FwIonOH0-U56Qg2KxVPR1VsNYxQ2vAg1oZoxMTXFBEIVdCstcv9rghv-LNEro6oMWZEiJ3UbO44AQYs5rKYm7_ko535F3I9mikl_fOmJtnuR4Xm5WhJSEATnVAARY\"/>\n</div>\n</div>\n</section>\n<!-- Right Side: Current Step (Fixed/Dynamic Focus) -->\n<section class=\"w-full md:w-2/3 h-1/2 md:h-full bg-white flex flex-col justify-center p-8 md:p-16 overflow-y-auto\">\n<div class=\"max-w-4xl\">\n<span class=\"font-headline font-black text-primary text-2xl md:text-4xl mb-4 block tracking-tight\">STEP 02</span>\n<h2 class=\"font-headline font-black text-4xl md:text-7xl lg:text-8xl leading-[0.9] uppercase tracking-tighter mb-12\">\n                    Whisk egg yolks and cheese until <span class=\"text-primary\">thick cream</span> forms.\n                </h2>\n<div class=\"flex flex-col sm:flex-row gap-8 items-start\">\n<div class=\"flex-1 border-l-8 border-black pl-6\">\n<p class=\"font-body text-xl font-medium leading-relaxed\">\n                            Combine the egg yolks with most of the grated pecorino. Whisk vigorously. The texture should be pale and dense. Add a splash of pasta water if too dry.\n                        </p>\n</div>\n<div class=\"w-full sm:w-48 h-48 bg-primary-container border-4 border-black relative group flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-white text-6xl group-hover:scale-110 transition-transform\">timer</span>\n<div class=\"absolute -bottom-4 -right-4 bg-black text-white px-4 py-2 font-headline font-bold text-xl\">\n                            4 MINS\n                        </div>\n</div>\n</div>\n</div>\n</section>\n</main>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex h-24 divide-x-4 divide-black dark:divide-white bg-white dark:bg-stone-900 border-t-4 border-black dark:border-white\">\n<!-- Previous Action -->\n<a class=\"flex flex-1 items-center justify-center text-black dark:text-white py-6 h-full font-['Space_Grotesk'] font-bold uppercase text-xl hover:bg-[#a93800] hover:text-white active:scale-95 transition-all\" href=\"#\">\n<span class=\"material-symbols-outlined mr-2\">arrow_back</span>\n            PREVIOUS\n        </a>\n<!-- Next Action (Active Intent) -->\n<a class=\"flex flex-1 items-center justify-center bg-black dark:bg-white text-white dark:text-black py-6 h-full font-['Space_Grotesk'] font-bold uppercase text-xl hover:bg-[#a93800] hover:text-white active:scale-95 transition-all\" href=\"#\">\n            NEXT\n            <span class=\"material-symbols-outlined ml-2\">arrow_forward</span>\n</a>\n</nav>\n<!-- Hard Shadow FAB (Only for specific mode-related utility) -->\n<div class=\"fixed bottom-32 right-8 z-40 hidden md:block\">\n<button class=\"bg-primary text-white border-4 border-black w-20 h-20 flex items-center justify-center transition-all hover:-translate-x-1 hover:-translate-y-1 active:translate-x-0 active:translate-y-0\" style=\"box-shadow: 8px 8px 0px 0px #1b1b1b;\">\n<span class=\"material-symbols-outlined text-4xl\" style=\"font-variation-settings: 'FILL' 1;\">mic</span>\n</button>\n</div>\n</body></html>"}
