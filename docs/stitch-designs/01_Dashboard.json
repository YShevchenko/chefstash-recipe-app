ransition-all duration-300\" data-alt=\"glossy chocolate ganache cake with sharp edges on a white pedestal stand, dramatic lighting\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCbhRtYxaXpOsqjsLtux8BSsz3FfKjAoc62fCskFO6TqTcYlrBcP-R5_2Nl5XlX1ACs8juucS2nA3uDe78NxFCg3Uwk3xmjcJdkvRwrDEsSYA31nvTBsG1UR6H-Qo_df9lvJMDuqbCkQFh_jSOghhJN_0XlrdG9UPQlWhs9EulaAlVrwUPglE_fPru79rnIPDyQFrxX1TuN4sTnXrAOBSz4TOcpa76A_RXRgSOyQLWz7F0ndWeA3Ngok8QXk12oabNhRh-J8rOQ9RfF\"/>\n</div>\n<div class=\"p-3\">\n<span class=\"font-label font-bold text-[10px] text-primary uppercase block mb-1\">Dessert</span>\n<h3 class=\"font-headline font-bold text-lg leading-none uppercase text-on-surface\">DARK COCOA MONOLITH</h3>\n</div>\n</div>\n</div>\n<!-- Item 6 -->\n<div class=\"masonry-item-medium group\">\n<div class=\"h-full border-2 border-on-surface bg-surface flex flex-col hover:border-4 transition-all duration-75\">\n<div class=\"flex-grow overflow-hidden border-b-2 border-on-surface\">\n<img class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-300\" data-alt=\"vibrant green kale and avocado bowl with toasted pumpkin seeds and lemon wedge\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDRi0T2hmFt6kBUNT1iJwuygOp-KWeDIlm0exrBp0tMQmtioy45kRznRG-WiSD0z7FVQlKdmbbML-X_hG_mR6eiz0bhIJVR2_ANr6RbFXvm83sM0ssnQPZhP_hSZKkjJen9MYSdO9H9MWenobuOLcmamr4ypsUITijFd8oHa2MVH0LSZxzj8QICGL8w1a2Rc8m9lU3o7MZMH-R5sGNZJZr2ZWa5nD_l7v5UBUxsu1p1WR6NgFVX0r60D8CKJMF28q986yNbi3kO6sgO\"/>\n</div>\n<div class=\"p-3\">\n<span class=\"font-label font-bold text-[10px] text-primary uppercase block mb-1\">Clean</span>\n<h3 class=\"font-headline font-bold text-lg leading-none uppercase text-on-surface\">GREEN KALE ASSEMBLY</h3>\n</div>\n</div>\n</div>\n</div>\n</main>\n<!-- FAB -->\n<button class=\"fixed bottom-24 right-6 w-16 h-16 bg-primary text-white border-4 border-on-surface brutalist-shadow active:scale-95 transition-transform z-40 flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-4xl\" data-icon=\"add\" style=\"font-variation-settings: 'FILL' 0;\">add</span>\n</button>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-stretch h-20 bg-[#f9f9f9] dark:bg-[#1b1b1b] border-t-4 border-solid border-[#1b1b1b]\">\n<!-- VAULT (Active) -->\n<div class=\"flex flex-col items-center justify-center bg-[#a93800] text-white p-2 border-r-2 border-l-2 border-[#1b1b1b] flex-1 active:scale-95 transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"grid_view\" style=\"font-variation-settings: 'FILL' 1;\">grid_view</span>\n<span class=\"font-['Space_Grotesk'] font-bold text-xs uppercase\">VAULT</span>\n</div>\n<!-- EXPLORE -->\n<div class=\"flex flex-col items-center justify-center text-[#1b1b1b] dark:text-[#f9f9f9] p-2 flex-1 hover:bg-[#e2e2e2] dark:hover:bg-[#5e5e5e] active:scale-95 transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"local_fire_department\">local_fire_department</span>\n<span class=\"font-['Space_Grotesk'] font-bold text-xs uppercase\">EXPLORE</span>\n</div>\n<!-- SAVED -->\n<div class=\"flex flex-col items-center justify-center text-[#1b1b1b] dark:text-[#f9f9f9] p-2 flex-1 hover:bg-[#e2e2e2] dark:hover:bg-[#5e5e5e] active:scale-95 transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"bookmark\">bookmark</span>\n<span class=\"font-['Space_Grotesk'] font-bold text-xs uppercase\">SAVED</span>\n</div>\n<!-- PROFILE -->\n<div class=\"flex flex-col items-center justify-center text-[#1b1b1b] dark:text-[#f9f9f9] p-2 flex-1 hover:bg-[#e2e2e2] dark:hover:bg-[#5e5e5e] active:scale-95 transition-transform\">\n<span class=\"material-symbols-outlined\" data-icon=\"person\">person</span>\n<span class=\"font-['Space_Grotesk'] font-bold text-xs uppercase\">PROFILE</span>\n</div>\n</nav>\n</body></html>"}
